          "BTTTriggerClass" : "BTTTriggerTypeKeyboardShortcut",
          "BTTUUID" : "55FAE882-A9B2-439B-B90D-5B525962CC7F",
          "BTTPredefinedActionType" : 172,
          "BTTPredefinedActionName" : "Run Apple Script (blocking)",
          "BTTAdditionalActionData" : {
            "BTTAppleScriptRunInBackground" : false,
            "BTTAIScriptType" : 3,
            "BTTScriptType" : 0,
            "BTTAppleScriptString" : "tell application \"System Events\"\n    set frontApp to name of first application process whose frontmost is true\n    \n    if frontApp is \"Mail\" then\n        tell application \"Calendar\"\n            activate\n            reopen\n        end tell\n    else if frontApp is \"Calendar\" then\n        tell application \"Mail\"\n            activate\n            reopen\n        end tell\n    else\n        tell application \"Mail\"\n            activate\n            reopen\n        end tell\n    end if\nend tell",
            "SelectedAction" : 172,
            "BTTAppleScriptUsePath" : false,
            "BTTScriptLocation" : 0
          },
          "BTTInlineAppleScript" : "tell application \"System Events\"\n    set frontApp to name of first application process whose frontmost is true\n    \n    if frontApp is \"Mail\" then\n        tell application \"Calendar\"\n            activate\n            reopen\n        end tell\n    else if frontApp is \"Calendar\" then\n        tell application \"Mail\"\n            activate\n            reopen\n        end tell\n    else\n        tell application \"Mail\"\n            activate\n            reopen\n        end tell\n    end if\nend tell",
          "BTTShortcutKeyboardType" : 0,
          "BTTShortcutKeyCode" : 12,
          "BTTShortcutModifierKeys" : 1966080,
          "BTTOrder" : 0,
          "BTTAutoAdaptToKeyboardLayout" : 0,
          "BTTIconData" : "",
          "BTTAlternateIconData" : ""
        },
        {
          "BTTLastUpdatedAt" : 1773400969.6260219,
          "BTTTriggerType" : 0,
          "BTTTriggerClass" : "BTTTriggerTypeKeyboardShortcut",
          "BTTUUID" : "43D5DDEC-DEBB-433A-848F-922FFBD66F69",
          "BTTPredefinedActionType" : 172,
          "BTTPredefinedActionName" : "Run Apple Script (blocking)",
          "BTTAdditionalActionData" : {
            "BTTAppleScriptRunInBackground" : false,
            "BTTAIScriptType" : 3,
            "BTTScriptType" : 0,
            "BTTAppleScriptString" : "tell application \"System Events\"\n\tset frontApp to name of first application process whose frontmost is true\n\t\n\tif frontApp is \"WhatsApp\" then\n\t\ttell application \"Signal\"\n\t\t\tactivate\n\t\t\treopen\n\t\tend tell\n\telse if frontApp is \"Signal\" then\n\t\ttell application \"Telegram\"\n\t\t\tactivate\n\t\t\treopen\n\t\tend tell\n\telse if frontApp is \"Telegram\" then\n\t\ttell application \"WhatsApp\"\n\t\t\tactivate\n\t\t\treopen\n\t\tend tell\n\telse\n\t\t-- None of the messaging apps are frontmost, start with WhatsApp\n\t\ttell application \"WhatsApp\"\n\t\t\tactivate\n\t\t\treopen\n\t\tend tell\n\tend if\nend tell",
            "SelectedAction" : 172,
            "BTTAppleScriptUsePath" : false,
            "BTTScriptLocation" : 0
          },
          "BTTInlineAppleScript" : "tell application \"System Events\"\n\tset frontApp to name of first application process whose frontmost is true\n\t\n\tif frontApp is \"WhatsApp\" then\n\t\ttell application \"Signal\"\n\t\t\tactivate\n\t\t\treopen\n\t\tend tell\n\telse if frontApp is \"Signal\" then\n\t\ttell application \"Telegram\"\n\t\t\tactivate\n\t\t\treopen\n\t\tend tell\n\telse if frontApp is \"Telegram\" then\n\t\ttell application \"WhatsApp\"\n\t\t\tactivate\n\t\t\treopen\n\t\tend tell\n\telse\n\t\t-- None of the messaging apps are frontmost, start with WhatsApp\n\t\ttell application \"WhatsApp\"\n\t\t\tactivate\n\t\t\treopen\n\t\tend tell\n\tend if\nend tell",
