          "BTTTriggerClass" : "BTTTriggerTypeKeyboardShortcut",
          "BTTUUID" : "C4FCA93A-1D4B-41E2-A4D8-0C7D2EAF912F",
          "BTTPredefinedActionType" : 172,
          "BTTPredefinedActionName" : "Run Apple Script (blocking)",
          "BTTAdditionalActionData" : {
            "BTTAppleScriptRunInBackground" : false,
            "BTTAIScriptType" : 3,
            "BTTScriptType" : 0,
            "BTTAppleScriptString" : "tell application \"System Events\"\n    set frontApp to name of first application process whose frontmost is true\n    \n    if frontApp is \"Slack\" then\n        tell application \"Discord\"\n            activate\n            reopen\n        end tell\n    else if frontApp is \"Discord\" then\n        tell application \"Slack\"\n            activate\n            reopen\n        end tell\n    else\n        -- None of the chat apps are frontmost, start with Slack\n        tell application \"Slack\"\n            activate\n            reopen\n        end tell\n    end if\nend tell",
            "SelectedAction" : 172,
            "BTTAppleScriptUsePath" : false,
            "BTTScriptLocation" : 0
          },
          "BTTInlineAppleScript" : "tell application \"System Events\"\n    set frontApp to name of first application process whose frontmost is true\n    \n    if frontApp is \"Slack\" then\n        tell application \"Discord\"\n            activate\n            reopen\n        end tell\n    else if frontApp is \"Discord\" then\n        tell application \"Slack\"\n            activate\n            reopen\n        end tell\n    else\n        -- None of the chat apps are frontmost, start with Slack\n        tell application \"Slack\"\n            activate\n            reopen\n        end tell\n    end if\nend tell",
          "BTTShortcutKeyboardType" : 0,
          "BTTShortcutKeyCode" : 0,
          "BTTShortcutModifierKeys" : 1966080,
          "BTTOrder" : 17,
          "BTTAutoAdaptToKeyboardLayout" : 0,
