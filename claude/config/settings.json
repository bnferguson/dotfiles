      "Bash(kubectl rollout:*)",
      "Bash(kubectl delete:*)",
      "Bash(kubectl apply:*)",
      "Bash(kubectl wait:*)",
      "Bash(kubectl run:*)",
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go mod:*)",
      "Bash(golangci-lint run:*)",
      "Bash(gofmt:*)",
      "Bash(bin/rails:*)",
      "Bash(bundle:*)",
      "Bash(rubocop:*)",
      "Bash(bin/rubocop:*)",
      "Bash(bin/brakeman:*)",
      "Bash(ruby:*)",
      "Bash(mise:*)",
      "Bash(pnpm:*)",
      "Bash(node:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(ps:*)",
      "Bash(lsof:*)",
      "Bash(pgrep:*)",
      "Bash(pkill:*)",
      "Bash(kill:*)",
      "Bash(chmod:*)",
      "Bash(echo:*)",
      "Bash(tee:*)",
      "Bash(xargs:*)",
      "Bash(jq:*)",
      "Bash(curl:*)",
      "Bash(cd:*)",
      "Bash(bash:*)",
      "Bash(source:*)",
      "Bash(which:*)",
      "Bash(make:*)",
      "Bash(timeout:*)",
      "Bash(actionlint:*)",
      "Bash(ast-grep:*)",
      "Bash(python3:*)",
      "Bash(aws ecr get-login-password:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:docs.google.com)",
      "WebFetch(domain:guides.rubyonrails.org)",
      "WebFetch(domain:playwright.dev)",
      "WebFetch(domain:posthog.com)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:www.w3.org)",
      "WebFetch(domain:www.hashicorp.com)",
      "WebFetch(domain:linear.app)",
      "WebFetch(domain:storybook.js.org)",
      "WebFetch(domain:javascript.info)",
      "WebFetch(domain:dev.to)",
      "WebFetch(domain:medium.com)",
      "mcp__claude_ai_Mermaid_Chart__validate_and_render_mermaid_diagram",
      "mcp__plugin_playwright_playwright__browser_take_screenshot",
      "mcp__plugin_playwright_playwright__browser_navigate",
      "mcp__plugin_playwright_playwright__browser_click",
      "mcp__plugin_playwright_playwright__browser_snapshot",
      "mcp__plugin_playwright_playwright__browser_console_messages",
      "mcp__plugin_playwright_playwright__browser_run_code",
      "mcp__plugin_playwright_playwright__browser_close",
      "mcp__plugin_playwright_playwright__browser_network_requests",
      "mcp__plugin_playwright_playwright__browser_evaluate",
      "mcp__plugin_playwright_playwright__browser_wait_for",
      "Skill(mesa-resolve)",
      "Skill(mesa-fix)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo *)",
      "Bash(mkfs *)",
      "Bash(dd *)",
      "Bash(wget *|bash*)",
      "Bash(curl *|bash*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git checkout -- .)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.bash_profile)",
      "Edit(~/.zprofile)",
      "Edit(~/.ssh/**)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.git-credentials)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/**)",
      "Read(~/.npmrc)",
      "Read(~/.npm/**)",
      "Read(~/.pypirc)",
      "Read(~/.gem/credentials)",
      "Read(~/Library/Keychains/**)"
    ],
    "ask": [],
    "defaultMode": "default"
  },
  "enableAllProjectMcpServers": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/block-rm-rf.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/block-push-to-main.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/enforce-package-manager.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/log-mutations.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/log-sandbox-bypass.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "command -v jj >/dev/null && jj root >/dev/null 2>&1 && jj status || true"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "command -v jj >/dev/null && jj root >/dev/null 2>&1 && jj status || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "command -v jj >/dev/null && jj root >/dev/null 2>&1 && jj show --summary || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "ast-grep@ast-grep-marketplace": true,
    "ruby-skills@ruby-skills": true,
    "gh-cli@trailofbits": true,
    "ask-questions-if-underspecified@trailofbits": true,
    "differential-review@trailofbits": true,
    "git-cleanup@trailofbits": true,
    "property-based-testing@trailofbits": true,
    "skill-improver@trailofbits": true,
    "testing-handbook-skills@trailofbits": true,
    "slack@claude-plugins-official": true,
    "zls-lsp@zig-skills": true,
    "clangd-lsp@claude-plugins-official": true,
    "skills-janitor@skills-janitor": true
  },
  "extraKnownMarketplaces": {
    "ruby-skills": {
      "source": {
        "source": "github",
        "repo": "bnferguson/ruby-skills"
      }
    },
    "trailofbits": {
      "source": {
        "source": "github",
        "repo": "trailofbits/skills"
      }
    },
    "zig-skills": {
      "source": {
        "source": "github",
        "repo": "bnferguson/zig-skills"
      }
    },
    "skills-janitor": {
      "source": {
        "source": "github",
        "repo": "khendzel/skills-janitor"
      }
    }
  },
  "sandbox": {
    "filesystem": {
      "allowWrite": [
        "/tmp",
        "/private/tmp",
        "/private/var/folders",
        "~/.cache",
        "~/.claude/audit"
      ],
      "allowRead": [
        "~/.config/gh"
      ]
    },
    "excludedCommands": [
      "gh *",
      "git push *",
      "git fetch *",
      "mise *"
    ]
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Hitting the tabletop",
      "Sending it off the ramp",
      "Pulling a backflip",
      "Pedaling to Helltrack",
      "Waxing the chain",
      "Catching air",
      "Racing Bart Taylor",
      "Dialing in the endo",
      "Dodging the bulldozers",
      "Riding through the creek",
      "Registering for Helltrack",
      "Tightening the spokes",
      "Airing out the quarter pipe",
      "Dancing at the school gym",
      "Training with Aunt Becky",
      "Styling a no-hander",
      "Bunny hopping the hay bales",
      "Dropping into the half pipe",
      "Qualifying for the finals",
      "Breaking away from the pack",
      "Overrotating",
      "Sending an angel",
      "Breaking the ice",
      "Thundering in your heart"
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
