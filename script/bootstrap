#!/usr/bin/env bash
#
# bootstrap installs things.

cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd -P)

set -e

echo ''

info () {
  printf "\r  [ \033[00;34m..\033[0m ] $1\n"
}

user () {
  printf "\r  [ \033[0;33m??\033[0m ] $1\n"
}

success () {
  printf "\r\033[2K  [ \033[00;32mOK\033[0m ] $1\n"
}

fail () {
  printf "\r\033[2K  [\033[0;31mFAIL\033[0m] $1\n"
  echo ''
  exit
}

setup_gitconfig () {
  if ! [ -f git/gitconfig.local.symlink ]
  then
    info 'setup gitconfig'

    git_credential='cache'
    if [ "$(uname -s)" == "Darwin" ]
    then
      git_credential='osxkeychain'
    fi

    user ' - What is your github author name?'
    read -e git_authorname
    user ' - What is your github author email?'
    read -e git_authoremail

    sed -e "s/AUTHORNAME/$git_authorname/g" -e "s/AUTHOREMAIL/$git_authoremail/g" -e "s/GIT_CREDENTIAL_HELPER/$git_credential/g" git/gitconfig.local.symlink.example > git/gitconfig.local.symlink

    success 'gitconfig'
  fi
}


link_file () {
  local src=$1 dst=$2

  local overwrite= backup= skip=
  local action=

  if [ -f "$dst" -o -d "$dst" -o -L "$dst" ]
  then

    if [ "$overwrite_all" == "false" ] && [ "$backup_all" == "false" ] && [ "$skip_all" == "false" ]
    then

      # Compare resolved real paths to handle both relative and absolute symlinks
      local currentRealPath=""
      if [ -L "$dst" ]; then
        currentRealPath=$(perl -MCwd -e 'print Cwd::realpath($ARGV[0]) // ""' "$dst" 2>/dev/null)
      fi

      if [ "$currentRealPath" == "$src" ]
      then

        skip=true;

      else

        user "File already exists: $dst ($(basename "$src")), what do you want to do?\n\
        [s]kip, [S]kip all, [o]verwrite, [O]verwrite all, [b]ackup, [B]ackup all?"
        read -n 1 action

        case "$action" in
          o )
            overwrite=true;;
          O )
            overwrite_all=true;;
          b )
            backup=true;;
          B )
            backup_all=true;;
          s )
            skip=true;;
          S )
            skip_all=true;;
          * )
            ;;
        esac

      fi

    fi

    overwrite=${overwrite:-$overwrite_all}
    backup=${backup:-$backup_all}
    skip=${skip:-$skip_all}

    if [ "$overwrite" == "true" ]
    then
      rm -rf "$dst"
      success "removed $dst"
    fi

    if [ "$backup" == "true" ]
    then
      mv "$dst" "${dst}.backup"
      success "moved $dst to ${dst}.backup"
    fi

    if [ "$skip" == "true" ]
    then
      success "skipped $src"
    fi
  fi

  if [ "$skip" != "true" ]  # "false" or empty
  then
    # Use relative symlinks so they work regardless of absolute path
    local dst_real_dir
    dst_real_dir="$(cd "$(dirname "$2")" && pwd -P)"
    local rel_src
    rel_src=$(perl -MFile::Spec -e 'print File::Spec->abs2rel($ARGV[0], $ARGV[1])' "$1" "$dst_real_dir")
    ln -s "$rel_src" "$2"
    success "linked $rel_src to $2"
  fi
}


install_dotfiles () {
  info 'installing dotfiles'

  local overwrite_all=false backup_all=false skip_all=false

  for src in $(find -H "$DOTFILES_ROOT" -maxdepth 2 -name '*.symlink' -not -path '*.git*')
  do
    dst="$HOME/.$(basename "${src%.*}")"
    link_file "$src" "$dst"
  done
}

install_larger_paths () {
  info 'adding paths that do not live in root'

  local overwrite_all=false backup_all=false skip_all=false

  mkdir -p "$HOME/.config"
  mkdir -p "$HOME/.claude"
  link_file "$DOTFILES_ROOT/nvim" "$HOME/.config/nvim"
  link_file "$DOTFILES_ROOT/starship/starship.toml" "$HOME/.config/starship.toml"
  mkdir -p "$HOME/.config/mise"
  link_file "$DOTFILES_ROOT/mise/config.toml" "$HOME/.config/mise/config.toml"

  mkdir -p "$HOME/.config/gh"
  link_file "$DOTFILES_ROOT/gh/config.yml" "$HOME/.config/gh/config.yml"

  mkdir -p "$HOME/.config/git"
  link_file "$DOTFILES_ROOT/git/ignore" "$HOME/.config/git/ignore"

  mkdir -p "$HOME/.config/zed"
  link_file "$DOTFILES_ROOT/zed/settings.json" "$HOME/.config/zed/settings.json"
  link_file "$DOTFILES_ROOT/zed/keymap.json" "$HOME/.config/zed/keymap.json"

  mkdir -p "$HOME/.config/ghostty"
  link_file "$DOTFILES_ROOT/ghostty/config" "$HOME/.config/ghostty/config"

  mkdir -p "$HOME/.ssh"
  chmod 700 "$HOME/.ssh"
  link_file "$DOTFILES_ROOT/ssh/config" "$HOME/.ssh/config"

  # Claude Code config — symlink individual files to preserve ~/.claude session data.
  link_file "$DOTFILES_ROOT/claude/settings.json" "$HOME/.claude/settings.json"
  link_file "$DOTFILES_ROOT/claude/statusline.sh" "$HOME/.claude/statusline.sh"
  link_file "$DOTFILES_ROOT/claude/CLAUDE.md" "$HOME/.claude/CLAUDE.md"
  link_file "$DOTFILES_ROOT/claude/style-guide.md" "$HOME/.claude/style-guide.md"
  link_file "$DOTFILES_ROOT/claude/tropes.md" "$HOME/.claude/tropes.md"
  link_file "$DOTFILES_ROOT/claude/skills" "$HOME/.claude/skills"
  link_file "$DOTFILES_ROOT/claude/agents" "$HOME/.claude/agents"

  mkdir -p "$HOME/.config/jj"
  link_file "$DOTFILES_ROOT/jj/config.toml" "$HOME/.config/jj/config.toml"

  if [ "$(uname -s)" == "Darwin" ]; then
    link_file "$DOTFILES_ROOT/karabiner" "$HOME/.config/karabiner"
  fi
}

setup_jjconfig () {
  local confd="$HOME/.config/jj/conf.d"
  if ! [ -f "$confd/local.toml" ]
  then
    info 'setup jj user config (reusing git author info)'

    # Fall back to parsing the existing git local config if variables weren't set
    if [ -z "$git_authorname" ] && [ -f git/gitconfig.local.symlink ]; then
      git_authorname=$(git config -f git/gitconfig.local.symlink user.name)
      git_authoremail=$(git config -f git/gitconfig.local.symlink user.email)
    fi

    mkdir -p "$confd"
    sed -e "s/AUTHORNAME/$git_authorname/g" -e "s/AUTHOREMAIL/$git_authoremail/g" jj/config.local.toml.example > "$confd/local.toml"

    success 'jj user config'
  fi
}

setup_gitconfig
setup_jjconfig
install_dotfiles
install_larger_paths

# Trust the mise config at its real path so mise doesn't prompt in sandboxed environments
if command -v mise &>/dev/null; then
  mise trust "$DOTFILES_ROOT/mise/config.toml" 2>/dev/null || true
fi

# If we're on a Mac, let's install and setup homebrew.
if [ "$(uname -s)" == "Darwin" ]
then
  info "installing dependencies"
  if source bin/dot | while read -r data; do info "$data"; done
  then
    success "dependencies installed"
  else
    fail "error installing dependencies"
  fi
fi

# BetterTouchTool — import presets if BTT is reachable, otherwise remind.
if [ "$(uname -s)" == "Darwin" ]; then
  BTTCLI="/Applications/BetterTouchTool.app/Contents/SharedSupport/bin/bttcli"
  if [ -x "$BTTCLI" ] && "$BTTCLI" get_preset_details > /dev/null 2>&1; then
    info "importing BetterTouchTool presets"
    "$DOTFILES_ROOT/bettertouchtool/import"
    success "BetterTouchTool presets imported"
  else
    info "BetterTouchTool: skipped preset import (BTT not running or Socket Server not enabled)"
    info "  To import later: bettertouchtool/import"
    info "  Enable Socket Server: BTT → Settings → Scripting → Command Line"
  fi
fi

echo ''
echo '  All installed!'
