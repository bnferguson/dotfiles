#!/usr/bin/env bash
#
# Run all dotfiles installers.

set -e

cd "$(dirname $0)"/..

# Install packages
if command -v brew >/dev/null 2>&1; then
  echo "› brew bundle"
  brew bundle --file=Brewfile
elif command -v pacman >/dev/null 2>&1; then
  echo "› installing packages via pacman"
  sudo pacman -S --needed --noconfirm \
    zsh starship mise neovim github-cli jq yq fzf fd ast-grep uv jujutsu keyd \
    ttf-ibmplex-mono-nerd \
    firefox telegram-desktop signal-desktop

  # AUR packages — yay is the assumed helper (ships with Omarchy)
  if command -v yay >/dev/null 2>&1; then
    echo "› installing AUR packages via yay"
    yay -S --needed --noconfirm slack-desktop
  else
    echo "  Note: yay not found; skipping AUR packages (slack-desktop)"
  fi

  # keyd — system-level key remapper for Hyper key (Caps Lock → Esc/Hyper)
  DOTFILES_ROOT="$(cd "$(dirname "$0")/.." && pwd -P)"
  if [ -f "$DOTFILES_ROOT/linux/keyd/default.conf" ]; then
    echo "› configuring keyd"
    sudo cp "$DOTFILES_ROOT/linux/keyd/default.conf" /etc/keyd/default.conf
    sudo systemctl enable keyd
    sudo systemctl restart keyd
  fi
elif command -v apt-get >/dev/null 2>&1; then
  echo "› installing packages via apt"
  sudo apt-get update
  sudo apt-get install -y zsh neovim jq fzf fd-find
  # These need separate install methods on Ubuntu:
  # starship: curl -sS https://starship.rs/install.sh | sh
  # mise:     curl https://mise.run | sh
  # gh:       https://github.com/cli/cli/blob/trunk/docs/install_linux.md
  echo "  Note: starship, mise, and gh need manual install on Ubuntu — see README"
fi

# Switch default shell to whatever shell.env declares, if it isn't already.
# shell.env is the single source of truth for the shell path.
if [ -f shell.env ]; then
  desired_shell="$(. ./shell.env && echo "$SHELL")"
  if [ -x "$desired_shell" ]; then
    if command -v getent >/dev/null 2>&1; then
      current_shell="$(getent passwd "$USER" | cut -d: -f7)"
    elif command -v dscl >/dev/null 2>&1; then
      current_shell="$(dscl . -read "/Users/$USER" UserShell 2>/dev/null | awk '{print $2}')"
    else
      current_shell="$SHELL"
    fi
    if [ "$current_shell" != "$desired_shell" ]; then
      echo "› changing default shell to $desired_shell"
      if ! grep -qx "$desired_shell" /etc/shells; then
        echo "$desired_shell" | sudo tee -a /etc/shells >/dev/null
      fi
      chsh -s "$desired_shell"
    fi
  else
    echo "  Note: shell.env points to $desired_shell but it isn't executable; skipping chsh"
  fi
fi

# Run topic installers
find . -name install.sh -not -path './.git/*' -not -path './script/*' | while read installer ; do
  echo "› running $installer"
  sh -c "${installer}"
done
